[1.6, "o", "\u001b[38;5;81mconst\u001b[0m express = \u001b[38;5;81mrequire\u001b[0m(\u001b[38;5;186m'express'\u001b[0m);\r\n"]
[1.7, "o", "\u001b[38;5;81mconst\u001b[0m app = express();\r\n\r\n"]
[1.8, "o", "app.get(\u001b[38;5;186m'/users'\u001b[0m, \u001b[38;5;81masync\u001b[0m (req, res) => {\r\n"]
[1.9, "o", "  \u001b[38;5;81mvar\u001b[0m password = \u001b[38;5;186m'admin123'\u001b[0m;\r\n"]
[2.0, "o", "  \u001b[38;5;81mconst\u001b[0m data = \u001b[38;5;81mawait\u001b[0m fetch(\u001b[38;5;186m'http://'\u001b[0m+req.query.url);\r\n"]
[2.1, "o", "  eval(req.body.code);\r\n"]
